generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  groupId   String
  content   String   @db.Text
  timestamp DateTime @default(now())

  @@index([groupId])
}
